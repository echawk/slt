#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")"
cache_dir="$PWD/.cache"
separator=$(printf '\037')
cli_args=""

if [ "$#" -gt 0 ]; then
  cli_args=$1
  shift
  for arg in "$@"; do
    cli_args="${cli_args}${separator}${arg}"
  done
fi

exec env XDG_CACHE_HOME="$cache_dir" SLT_CLI_ARGS="$cli_args" qlot exec sbcl --noinform --no-sysinit --no-userinit --non-interactive \
  --eval '(setf uiop/lisp-build:*compile-file-warnings-behaviour* :warn uiop/lisp-build:*compile-file-failure-behaviour* :warn)' \
  --eval '(asdf:load-asd (merge-pathnames "slt.asd" (truename ".")))' \
  --eval '(asdf:load-system :slt)' \
  --eval '(slt:main)'
